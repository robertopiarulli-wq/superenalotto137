name: Data Sequence Analysis

on:
  workflow_dispatch: # Permette di avviarlo a mano dal tab "Actions" di GitHub
  schedule:
    - cron: '0 0 * * *' # Opzionale: gira ogni notte a mezzanotte

jobs:
  analyze:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
          cache: 'pip' # Velocizza i giri successivi

      - name: Install dependencies
        run: |
          pip install pandas numpy scipy supabase matplotlib

      - name: Run Analysis
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
        run: python scripts/data_analysis/main_analysis.py
